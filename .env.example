# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=replace_me

# Max output file size in MB (Telegram limit for your target workflow)
MAX_OUTPUT_MB=10

# Temp folder for downloads/transcodes
WORKDIR=./tmp

# Remove temporary folders older than N hours on each request
STALE_TMP_MAX_AGE_HOURS=24

# Optional: custom Telegram Bot API endpoint (for local Bot API server)
# Example:
# TELEGRAM_BASE_URL=http://127.0.0.1:8081/bot
# TELEGRAM_BASE_FILE_URL=http://127.0.0.1:8081/file/bot
TELEGRAM_BASE_URL=
TELEGRAM_BASE_FILE_URL=
